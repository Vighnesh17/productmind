# ============================================================
# ProductMind AI — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env — it is in .gitignore.
# ============================================================

# ── Anthropic ────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<id>/settings/api
# SUPABASE_URL: your project URL (https://<id>.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY: the secret "service_role" key — backend only, never expose to browser
# SUPABASE_ANON_KEY: the public "anon" key — used by Next.js frontend only
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# For local dev, supabase start outputs these automatically:
# SUPABASE_URL=http://localhost:54321
# SUPABASE_SERVICE_ROLE_KEY=<printed by supabase start>
# SUPABASE_ANON_KEY=<printed by supabase start>

# ── Database (direct Postgres connection for SQLAlchemy/Alembic) ──
# Local:      postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
# Production: get from Supabase dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ── Pinecone ─────────────────────────────────────────────────
# Get from: https://app.pinecone.io/ → API Keys
# PINECONE_INDEX: name of your index (e.g. "productmind-memory")
# Create index with: dimension=1536, metric=cosine
PINECONE_API_KEY=
PINECONE_INDEX=productmind-memory

# ── Upstash Redis ────────────────────────────────────────────
# Get from: https://console.upstash.com/ → Create Database → REST URL + Token
# Format: rediss://:TOKEN@HOST:PORT
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Auth0 ────────────────────────────────────────────────────
# Get from: https://manage.auth0.com/ → Applications → Your App → Settings
# AUTH0_DOMAIN:        your tenant domain (e.g. dev-abc123.us.auth0.com)
# AUTH0_CLIENT_ID:     your app's client ID
# AUTH0_CLIENT_SECRET: your app's client secret (M2M or Regular Web App)
# AUTH0_AUDIENCE:      your API identifier (e.g. https://api.productmind.ai)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=

# ── Inngest ──────────────────────────────────────────────────
# Get from: https://app.inngest.com/ → Your App → Signing Key
# Local dev: inngest dev generates a local signing key automatically
# INNGEST_EVENT_KEY:    used to send events to Inngest
# INNGEST_SIGNING_KEY:  used to verify Inngest webhook callbacks
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Doppler (optional — alternative to .env for team secrets) ─
# If using Doppler: run `doppler setup` instead of filling this file.
# Leave blank if managing secrets via .env directly.
DOPPLER_TOKEN=

# ── Jira OAuth ───────────────────────────────────────────────
# Get from: https://developer.atlassian.com/console/myapps/
# Create an OAuth 2.0 app with scopes: read:jira-work, read:jira-user
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/v1/integrations/jira/callback

# ── Slack OAuth ──────────────────────────────────────────────
# Get from: https://api.slack.com/apps → Create App → OAuth & Permissions
# Required scopes: channels:history, channels:read, users:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/v1/integrations/slack/callback

# ── App Config ───────────────────────────────────────────────
# Environment: local | staging | production
APP_ENV=local
APP_PORT=8000
LOG_LEVEL=INFO

# ── Frontend (Next.js — NEXT_PUBLIC_ vars are exposed to browser) ──
# These go in frontend/.env.local (not this file)
# Copy the block below into frontend/.env.local:
#
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_AUTH0_DOMAIN=<your AUTH0_DOMAIN>
# NEXT_PUBLIC_AUTH0_CLIENT_ID=<your AUTH0_CLIENT_ID>
# NEXT_PUBLIC_AUTH0_AUDIENCE=<your AUTH0_AUDIENCE>
# NEXT_PUBLIC_SUPABASE_URL=<your SUPABASE_URL>
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<your SUPABASE_ANON_KEY>
